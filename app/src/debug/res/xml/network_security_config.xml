<?xml version="1.0" encoding="utf-8"?>
<!--
   Debug-only override: permits cleartext (http://) so local/dev WooCommerce
   stores without TLS can be reached while testing. The main (release) config
   blocks cleartext.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
